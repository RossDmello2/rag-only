{
  "name": "rag-only",
  "version": "0.1.0",
  "description": "Static browser-only document RAG assistant for local Ollama and Qdrant workflows.",
  "type": "module",
  "private": true,
  "packageManager": "npm@11.6.0",
  "license": "MIT",
  "author": "Ross Dmello",
  "homepage": "https://github.com/RossDmello2/rag-only#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/RossDmello2/rag-only.git"
  },
  "bugs": {
    "url": "https://github.com/RossDmello2/rag-only/issues"
  },
  "keywords": [
    "rag",
    "retrieval-augmented-generation",
    "document-chat",
    "local-first",
    "ollama",
    "qdrant",
    "browser",
    "static-site",
    "vector-search",
    "pdf-chat"
  ],
  "scripts": {
    "serve": "node scripts/serve-static.js . 8000",
    "check:syntax": "node --check script.js && node --check scripts/serve-static.js",
    "test": "npm run test:unit",
    "test:unit": "node --test tests/*.test.js",
    "test:e2e": "playwright test",
    "verify": "npm run check:syntax && npm run test:unit && npm run test:e2e && npm audit --audit-level=high"
  },
  "engines": {
    "node": ">=22"
  },
  "devDependencies": {
    "@playwright/test": "^1.52.0"
  }
}
